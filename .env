# Auth token that must be sent in X-CSRF-Token header
API_TOKEN=my_secret_token_here

# CLIP model (ViT-B-32 is cached locally; ViT-B-16 / ViT-L-14 require download)
CLIP_MODEL=ViT-B-16
CLIP_PRETRAINED=openai

# Confidence threshold (0.0 - 1.0) for grid cell selection
GRID_THRESHOLD=0.55

# Server settings
HOST=0.0.0.0
PORT=8000
